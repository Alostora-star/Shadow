# نموذج لملف .env
# قم بنسخ هذا الملف إلى .env وأضف القيم الحقيقية

# توكن البوت من BotFather
BOT_TOKEN=your_bot_token_here

# معرف المسؤول (يمكن الحصول عليه من @userinfobot)
ADMIN_USER_ID=your_admin_user_id_here

# معرف القناة الإجبارية (اختياري)
GROUP_ID=your_group_id_here

# رابط القناة الإجبارية (اختياري)
GROUP_JOIN_LINK=https://t.me/your_channel
